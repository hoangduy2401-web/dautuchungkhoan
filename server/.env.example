# Copy to server/.env and fill in real values. NEVER commit .env.

# --- FastConnect DATA (giá, nến, chỉ số) ---
SSI_CONSUMER_ID=
SSI_CONSUMER_SECRET=
SSI_BASE_URL=https://fc-data.ssi.com.vn

# --- FastConnect TRADING (đọc danh mục thật, tùy chọn) ---
# Cặp credentials RIÊNG của Trading, không dùng chung với Data.
SSI_TRADING_CONSUMER_ID=
SSI_TRADING_CONSUMER_SECRET=
SSI_TRADE_BASE_URL=https://fc-tradeapi.ssi.com.vn
# Số tài khoản chứng khoán, vd: 1234567
SSI_ACCOUNT=
# 0 = PIN, 1 = OTP. PIN cho phép server tự làm mới token; OTP phải nhập tay mỗi phiên.
SSI_TRADING_2FA_TYPE=0
# Chỉ điền khi dùng PIN. Để trống nếu dùng OTP.
SSI_TRADING_PIN=

# --- Khóa bảo vệ endpoint /api/account/* ---
# Tự đặt chuỗi ngẫu nhiên dài. Không set = tính năng tài khoản tắt hoàn toàn.
DASHBOARD_API_KEY=

PORT=3001
